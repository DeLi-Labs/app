{
  "name": "@se-2/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-types": "tsc --noEmit --incremental",
    "codegen": "PONDER_GRAPHQL_URL=${PONDER_GRAPHQL_URL:-${NEXT_PUBLIC_PONDER_URL:-http://localhost:42069}/graphql} graphql-codegen --config codegen.yml",
    "codegen:watch": "PONDER_GRAPHQL_URL=${PONDER_GRAPHQL_URL:-${NEXT_PUBLIC_PONDER_URL:-http://localhost:42069}/graphql} graphql-codegen --config codegen.yml --watch",
    "dev": "next dev",
    "format": "prettier --write . '!(node_modules|.next|contracts)/**/*'",
    "ipfs": "NEXT_PUBLIC_IPFS_BUILD=true yarn build && yarn bgipfs upload config init -u https://upload.bgipfs.com && CID=$(yarn bgipfs upload out | grep -o 'CID: [^ ]*' | cut -d' ' -f2) && [ ! -z \"$CID\" ] && echo '🚀 Upload complete! Your site is now available at: https://community.bgipfs.com/ipfs/'$CID || echo '❌ Upload failed'",
    "lint": "next lint",
    "next:fund-admin-app": "node --env-file=.env ./scripts/fund-admin-app.mjs",
    "serve": "next start",
    "start": "next dev",
    "vercel": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=false --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "vercel:yolo": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=false --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env NEXT_PUBLIC_IGNORE_BUILD_ERROR=true --build-env VERCEL_TELEMETRY_DISABLED=1"
  },
  "dependencies": {
    "@farcaster/mini-app-solana": "^1.0.0",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@filoz/synapse-sdk": "^0.40.4",
    "@heroicons/react": "~2.1.5",
    "@privy-io/react-auth": "^3.22.2",
    "@privy-io/wagmi": "^4.0.6",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@scaffold-ui/components": "^0.1.10",
    "@scaffold-ui/debug-contracts": "^0.1.9",
    "@scaffold-ui/hooks": "^0.1.8",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "~5.59.15",
    "blo": "~1.2.0",
    "blockstore-core": "^6.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "daisyui": "5.0.9",
    "formidable": "^3.5.4",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0",
    "ipfs-unixfs-importer": "^16.1.5",
    "kubo-rpc-client": "~5.0.2",
    "next": "~15.2.8",
    "next-api-decorators": "^2.0.2",
    "next-nprogress-bar": "~2.3.13",
    "next-themes": "~0.3.0",
    "path-to-regexp": "^6.3.0",
    "pinata": "^2.5.6",
    "qrcode.react": "~4.0.1",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "react-hot-toast": "~2.4.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "usehooks-ts": "~3.1.0",
    "viem": "2.39.0",
    "wagmi": "2.19.5",
    "zustand": "~5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.0",
    "@graphql-codegen/typescript-graphql-request": "^6.0.0",
    "@graphql-codegen/typescript-operations": "^6.0.0",
    "@tailwindcss/postcss": "4.0.15",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/babel__core": "^7",
    "@types/formidable": "^3.5.1",
    "@types/node": "~18.19.50",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "abitype": "1.0.6",
    "autoprefixer": "~10.4.20",
    "babel-plugin-parameter-decorator": "^1.0.16",
    "bgipfs": "~0.0.12",
    "eslint": "~9.23.0",
    "eslint-config-next": "~15.2.3",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "graphql-tag": "^2.12.6",
    "postcss": "~8.4.45",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "type-fest": "~4.26.1",
    "typescript": "~5.8.2",
    "vercel": "~51.2.1"
  },
  "packageManager": "yarn@4.13.0"
}
